#: esistatus/__init__.py:13 esistatus/templates/esistatus/base.html:6
msgid "ESI Status"
msgstr "Статус ESI"

#: esistatus/models.py:16
msgid "The ESI compatibility date."
msgstr "Дата сумісності ESI."

#: esistatus/models.py:21
msgid "The name ESI is currently going by. The three letters have never once meant the same thing twice."
msgstr ""

#: esistatus/models.py:30
msgid "The ESI status data."
msgstr "Дані статусу ESI."

#: esistatus/models.py:34
msgid "Total number of ESI endpoints."
msgstr "Загальна кількість ESI балів."

#: esistatus/models.py:43
msgid "ESI Endpoint Status"
msgstr "Статус ендпойнта ESI"

#: esistatus/models.py:44
msgid "ESI Endpoint Statuses"
msgstr "Статуси ендпойнтів ESI"

#: esistatus/templates/esistatus/base.html:13
#: esistatus/templates/esistatus/partials/dashboard-widget/esi-status.html:10
msgid "Status"
msgstr "Статус"

#: esistatus/templates/esistatus/index.html:11
msgid "Loading ESI status…"
msgstr "Завантаження статусу ESI …"

#: esistatus/templates/esistatus/partials/dashboard-widget/esi-status.html:17
#: esistatus/templates/esistatus/partials/index/esi-status.html:6
msgid "OK"
msgstr "OK"

#: esistatus/templates/esistatus/partials/dashboard-widget/esi-status.html:18
#: esistatus/templates/esistatus/partials/index/esi-status.html:7
msgid "These routes are working as expected."
msgstr "Ці маршрути працюють як треба."

#: esistatus/templates/esistatus/partials/dashboard-widget/esi-status.html:22
#: esistatus/templates/esistatus/partials/index/esi-status.html:11
msgid "Degraded"
msgstr "Прокачка знизилась"

#: esistatus/templates/esistatus/partials/dashboard-widget/esi-status.html:23
#: esistatus/templates/esistatus/partials/index/esi-status.html:12
msgid "These routes have a good chance of being slow or returning errors."
msgstr "Ці маршрути, скоріш за все, уповільнені або мають помилки."

#: esistatus/templates/esistatus/partials/dashboard-widget/esi-status.html:27
#: esistatus/templates/esistatus/partials/index/esi-status.html:16
msgid "Down"
msgstr "Прокачка впала"

#: esistatus/templates/esistatus/partials/dashboard-widget/esi-status.html:28
#: esistatus/templates/esistatus/partials/index/esi-status.html:17
msgid "These routes have a good chance of not responding at all or being completely unavailable."
msgstr "Ці маршрути не відповвідають зовсім або повністю недоступні."

#: esistatus/templates/esistatus/partials/dashboard-widget/esi-status.html:32
#: esistatus/templates/esistatus/partials/index/esi-status.html:21
msgid "Recovering"
msgstr "Відновлення"

#: esistatus/templates/esistatus/partials/dashboard-widget/esi-status.html:33
#: esistatus/templates/esistatus/partials/index/esi-status.html:22
msgid "These routes are recovering from previous issues and might not (yet) work as expected or might be slow."
msgstr "Ці маршрути відновлюються від попередніх складношів та можуть ще не працювати або бути уповільнені."

#: esistatus/templates/esistatus/partials/dashboard-widget/esi-status.html:37
#: esistatus/templates/esistatus/partials/index/esi-status.html:26
msgid "Unknown"
msgstr "Невідомо"

#: esistatus/templates/esistatus/partials/dashboard-widget/esi-status.html:38
#: esistatus/templates/esistatus/partials/index/esi-status.html:27
msgid "These routes have an unknown status."
msgstr "Ці маршрути мають невідомий статус."

#: esistatus/templates/esistatus/partials/dashboard-widget/esi-status.html:45
#: esistatus/templates/esistatus/partials/index/esi-status.html:34
#, python-format
msgid "%(esi_name)s compatibility date"
msgstr "Дата сумісності %(esi_name)s"

#: esistatus/templates/esistatus/partials/dashboard-widget/esi-status.html:59
msgid "Detailed ESI status"
msgstr "Детальний статус ESI"

#: esistatus/templates/esistatus/partials/dashboard-widget/esi-status.html:61
msgid "EVE Online status"
msgstr "Статус EVE Online"

#: esistatus/templates/esistatus/partials/dashboard-widget/esi-status.html:66
#: esistatus/templates/esistatus/partials/index/esi-status.html:47
msgid "No ESI status data is available at this time."
msgstr "Нема даних від ESI."

#: esistatus/templates/esistatus/partials/endpoints.html:64
msgid "View in ESI API Explorer"
msgstr "Показати ESI API Оглядач"

#: esistatus/templates/esistatus/partials/footer/app-translation-footer.html:5
msgid "Do you want to help translate this app into your language or improve the existing translation?"
msgstr "Хочете допомогти перекласти цю програму вашою мовою чи покращити наявний переклад?"

#: esistatus/templates/esistatus/partials/footer/app-translation-footer.html:8
msgid "Join our team of translators!"
msgstr "Приєднуйтесь до нашої команди перекладачів!"

#: esistatus/templates/esistatus/partials/index/esi-status.html:48
msgid "Please try again later."
msgstr "Будь ласка спробуйте пізніше."
